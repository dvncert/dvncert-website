# DVN Cert - Ortam değişkenleri örneği
# Gerçek değerleri .env.local'e koyun (git'e gitmez) ve Vercel > Settings > Environment Variables'a ekleyin.

# --- Vercel Postgres ---
# `vercel env pull .env.local` ile otomatik gelir (POSTGRES_URL ve diğerleri).
POSTGRES_URL=

# --- Auth.js (admin girişi) ---
# Üret: `npx auth secret`  veya  `openssl rand -base64 32`
AUTH_SECRET=

# --- İlk admin (yalnızca seed için; sonra DB'den yönetilir) ---
ADMIN_EMAIL=admin@dvncert.com
ADMIN_PASSWORD=

# --- Google Analytics ölçüm etiketi (sitede veri toplar) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-3VJDV7WQBG

# --- Yönetim panelinde GA4 + Search Console verisi (opsiyonel) ---
# Kurulum: docs/google-analytics-kurulum.md
# Servis hesabı anahtar dosyasının (JSON) tamamı. Düz JSON ya da base64 olabilir.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GA4 mülk (property) numarası — Analytics > Yönetici > Mülk ayarları (yalnızca rakam, ör. 123456789)
GA4_PROPERTY_ID=
# Search Console mülk adresi — alan adı mülkü için: sc-domain:dvncert.com / URL mülkü için: https://dvncert.com/
GSC_SITE_URL=sc-domain:dvncert.com
